# PostgreSQL connection string, e.g. postgresql://user:pass@localhost:5432/travel_amigo
DATABASE_URL=

# Upstash Redis (or any Redis) connection string, e.g. rediss://default:pass@host:6379
REDIS_URL=


# JWT signing secrets — generate with: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# SendGrid for transactional email (verification, trip invites)
SENDGRID_API_KEY=

# Google APIs — server-side only; never expose to the frontend
GOOGLE_PLACES_API_KEY=
GOOGLE_ROUTES_API_KEY=

# OpenWeather (optional enrichment)
OPENWEATHER_API_KEY=

# Cloudflare R2 (S3-compatible) for PDF storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Frontend origin allowed by CORS
CLIENT_URL=http://localhost:3000

# Port the API listens on (frontend expects 3001)
PORT=3001
